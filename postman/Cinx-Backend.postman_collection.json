    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/send-otp",
          "request": {
            "method": "POST",
            "description": "Send OTP for REGISTER/FORGOT_PASSWORD/UPDATE_PROFILE.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"purpose\": \"REGISTER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/send-otp"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200/400/404', function () {",
                  "  pm.expect([200,400,404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "description": "Register account with OTP. Optional role: student or instructor (default student).",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"12345678\",\n  \"fullName\": \"Nguyen Van A\",\n  \"otp\": \"123456\",\n  \"role\": \"instructor\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201/400', function () {",
                  "  pm.expect([201,400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "description": "Login and auto-save accessToken to collection variable.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cinx.local\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', function () {",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('accessToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/reset-password",
          "request": {
            "method": "POST",
            "description": "Reset password with OTP.",
