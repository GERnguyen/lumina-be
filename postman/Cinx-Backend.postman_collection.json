      "item": [
        {
          "name": "GET /api/courses",
          "request": {
            "method": "GET",
            "description": "List courses with filters and pagination.",
            "url": {
              "raw": "{{baseUrl}}/api/courses?categoryId={{categoryId}}&keyword=react&tag=mobile&page=1&limit=10&sortBy=best_seller&priceType=paid&isDiscounted=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "keyword", "value": "react" },
                { "key": "tag", "value": "mobile" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "best_seller" },
                { "key": "priceType", "value": "paid" },
                { "key": "isDiscounted", "value": "true" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Pagination envelope exists', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.property('total');",
                  "  pm.expect(json).to.have.property('page');",
